# API-ключ СамОтправил для инструмента api_request.
# Получить: https://samotpravil.ru/get-access
#
# Инструменты get_overview, list_endpoints, search_docs, get_endpoint
# работают без ключа — они читают https://documentation.samotpravil.ru/

SAMOTPRAVIL_API_KEY=

# Safety presets (рекомендуется для работы с AI-агентами):
# SAMOTPRAVIL_READ_ONLY=1
# SAMOTPRAVIL_ALLOW_SEND=0
# SAMOTPRAVIL_ALLOW_MUTATIONS=0
# SAMOTPRAVIL_ALLOW_GENERIC_API=0
#
# Python SDK (samotpravil==1.0.0rc1):
# SAMOTPRAVIL_PYTHON=python3
# SAMOTPRAVIL_ENABLE_PYTHON_SDK=0   # 1 = py_* tools в Node MCP через subprocess bridge
# SAMOTPRAVIL_ALLOW_WHITELABEL=1    # WhiteLabel-методы в Python MCP
#
# HTTP transport (--http): bind только на localhost по умолчанию
# SAMOTPRAVIL_HTTP_HOST=127.0.0.1
