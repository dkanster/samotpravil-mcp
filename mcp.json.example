{
  "mcpServers": {
    "samotpravil": {
      "command": "npx",
      "args": ["-y", "samotpravil-mcp@latest"],
      "env": {
        "SAMOTPRAVIL_API_KEY": "your_api_key_here"
      }
    },
    "swagger-mcp": {
      "command": "node",
      "args": ["/absolute/path/to/samotpravil-mcp/scripts/swagger-mcp-launcher.mjs"]
    }
  }
}
