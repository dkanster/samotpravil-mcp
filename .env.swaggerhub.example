# SwaggerHub — см. docs/SWAGGERHUB.md
# Скопируйте: cp .env.swaggerhub.example .env.swaggerhub
#
# API Key: https://app.swaggerhub.com/settings/apiKey
# Owner: username или org slug (регистр важен! npm run resolve-swaggerhub-owner)

SWAGGERHUB_API_KEY=
SWAGGERHUB_OWNER=

# Опционально
# SWAGGERHUB_API_NAME=samotpravil-smtp-api
# SWAGGERHUB_VERSION=1.0.0
# SWAGGERHUB_IS_PRIVATE=false

# Явный URL для Swagger-MCP (иначе — публичный SwaggerHub или data/openapi.yaml)
# SAMOTPRAVIL_SWAGGER_URL=https://api.swaggerhub.com/apis/mailganer/samotpravil-smtp-api/1.0.0
