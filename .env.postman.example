# Postman API key для Postman MCP Server (локальный stdio).
# Получить: https://go.postman.co/settings/me/api-keys
#
# Режимы (POSTMAN_MCP_MODE):
#   minimal — базовые операции с коллекциями, workspace, environments
#   code    — поиск API и генерация клиентского кода (рекомендуется)
#   full    — все 100+ инструментов Postman API

POSTMAN_API_KEY=
POSTMAN_MCP_MODE=code

# Для EU-региона раскомментируйте:
# POSTMAN_API_BASE_URL=https://api.eu.postman.com
