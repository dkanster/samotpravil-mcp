export const V2MailPackageSchema = dryRunSchema.extend({
  // TODO: add Zod fields from Postman body/query example
});

export async function handleV2MailPackage(params: z.infer<typeof V2MailPackageSchema>): Promise<string> {
  const { dry_run, ...rest } = params;
  const body = rest;
  return samotpravilRequest({
    method: "POST",
    path: "/api/v2/mail/package",
    body,
    dryRun: dry_run,
  });
}

